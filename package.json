{
  "name": "thandi-rag-system",
  "version": "0.1.0",
  "description": "Thandi AI Career Guidance Platform - RAG System",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:student": "jest --testPathPattern=student",
    "test:stack": "node scripts/test-thandi-stack.js",
    "test:rag": "node scripts/test-rag-query.js",
    "test:suite": "node scripts/test-rag-suite.js",
    "test:mock": "node scripts/test-mock-integration.js",
    "test:orchids": "node scripts/test-orchids-integration.js",
    "test:comprehensive": "node test-comprehensive-validation.js",
    "mock:server": "node scripts/mock-integration-test.js",
    "db:migrate": "node scripts/migrate-database.js",
    "db:seed": "node scripts/seed-knowledge-base.js",
    "embeddings:generate": "node scripts/generate-embeddings.js",
    "deploy:validate": "node scripts/deployment-config-validator.js",
    "deploy:validate:staging": "node scripts/deployment-config-validator.js staging",
    "deploy:validate:production": "node scripts/deployment-config-validator.js production",
    "deploy:start": "node scripts/deploy-enhanced-rag.js start",
    "deploy:start:staging": "node scripts/deploy-enhanced-rag.js start staging",
    "deploy:start:production": "node scripts/deploy-enhanced-rag.js start production",
    "deploy:start:dry-run": "node scripts/deploy-enhanced-rag.js start production --dry-run",
    "deploy:advance": "node scripts/deploy-enhanced-rag.js advance",
    "deploy:complete": "node scripts/deploy-enhanced-rag.js complete",
    "deploy:rollback": "node scripts/deploy-enhanced-rag.js rollback",
    "deploy:rollback:dry-run": "node scripts/deploy-enhanced-rag.js rollback --dry-run",
    "deploy:status": "node scripts/deploy-enhanced-rag.js status",
    "deploy:canary": "node scripts/deploy-enhanced-rag.js start production --skip-validation",
    "deploy:auto": "node scripts/deploy-enhanced-rag.js start production --auto-advance",
    "rollback:emergency": "node scripts/rollback-procedures.js emergency",
    "rollback:gradual": "node scripts/rollback-procedures.js gradual",
    "rollback:health-check": "node scripts/rollback-procedures.js health-check",
    "rollback:status": "node scripts/rollback-procedures.js status",
    "config:validate": "node scripts/deployment-config-validator.js",
    "config:validate:report": "node scripts/deployment-config-validator.js production --output=validation-report.json",
    "env:update": "node scripts/update-environment-variables.js update",
    "env:update:staging": "node scripts/update-environment-variables.js update staging",
    "env:update:production": "node scripts/update-environment-variables.js update production",
    "env:update:dry-run": "node scripts/update-environment-variables.js update production --dry-run",
    "env:template": "node scripts/update-environment-variables.js template",
    "env:template:staging": "node scripts/update-environment-variables.js template staging",
    "env:template:production": "node scripts/update-environment-variables.js template production",
    "env:validate": "node scripts/update-environment-variables.js validate",
    "env:validate:staging": "node scripts/update-environment-variables.js validate staging",
    "env:validate:production": "node scripts/update-environment-variables.js validate production"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.80.0",
    "dotenv": "^17.2.3",
    "groq-sdk": "^0.3.3",
    "jspdf": "^3.0.4",
    "next": "15.5.7",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^5.10.0",
    "tiktoken": "^1.0.22",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "fast-check": "^4.4.0",
    "jest": "^30.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
