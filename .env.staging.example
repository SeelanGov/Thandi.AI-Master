# Enhanced RAG Filtering - Staging Environment Configuration
# Copy this file to .env.staging and update with your staging values

# Deployment Environment
NODE_ENV=staging
RAG_DEPLOYMENT_ENV=staging

# Core Application URLs
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
OPENAI_API_KEY=your-openai-api-key

# Enhanced RAG Feature Flags - More aggressive testing in staging
RAG_FEATURE_ENHANCED_RAG_FILTERING=100
RAG_FEATURE_FALLBACK_CAREERS=100
RAG_FEATURE_PERFORMANCE_MONITORING=100
RAG_FEATURE_SUBJECT_CATEGORY_PRIORITIZATION=50
RAG_FEATURE_PROFILE_COMPLEXITY_ANALYSIS=50
RAG_FEATURE_ENHANCED_ERROR_HANDLING=100
RAG_FEATURE_ENHANCED_SAFETY_VALIDATION=100

# Performance Configuration - More lenient for testing
RAG_PERFORMANCE_TIMEOUT=8000
RAG_CACHE_TIMEOUT=180000
RAG_MAX_CONCURRENT_REQUESTS=5

# Monitoring and Analytics - Detailed for testing
RAG_ENABLE_DETAILED_LOGGING=true
RAG_ANALYTICS_RETENTION_DAYS=7
RAG_PERFORMANCE_ALERTS=true
RAG_DEBUG_MODE=true

# Safety and Compliance - Strict for validation
RAG_STRICT_SAFETY_MODE=true
RAG_REQUIRE_VERIFICATION_FOOTER=true
RAG_MAX_CAREER_COUNT=5
RAG_MIN_CAREER_COUNT=3

# Deployment Configuration
DEPLOYMENT_STAGE=staging
DEPLOYMENT_ROLLOUT_PERCENTAGE=100
DEPLOYMENT_AUTO_ADVANCE=true
DEPLOYMENT_HEALTH_CHECK_INTERVAL=60000

# Notification Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/staging/webhook
NOTIFICATION_EMAIL=staging-alerts@yourdomain.com

# Database Configuration
DATABASE_POOL_SIZE=5
DATABASE_TIMEOUT=15000
DATABASE_RETRY_ATTEMPTS=2

# Redis Configuration
REDIS_URL=redis://staging-redis:6379
REDIS_CACHE_PREFIX=rag_staging_

# Security Configuration - More permissive for testing
CORS_ORIGINS=*
API_RATE_LIMIT=1000
API_RATE_WINDOW=900000

# Logging Configuration - Verbose for debugging
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_DESTINATION=console

# Error Handling Configuration
ERROR_REPORTING_ENABLED=true
ERROR_SAMPLING_RATE=1.0

# Feature Flag Safeguards - More lenient for testing
RAG_SAFEGUARD_MAX_RESPONSE_TIME=8000
RAG_SAFEGUARD_MIN_CAREER_COUNT=3
RAG_SAFEGUARD_MAX_MEMORY_MB=150
RAG_SAFEGUARD_MIN_CONFIDENCE=0.3

# Testing Configuration
ENABLE_TEST_ENDPOINTS=true
MOCK_EXTERNAL_APIS=false
TEST_DATA_ENABLED=true